---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQSection from '../../components/FAQSection.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const siteUrl = import.meta.env.SITE || 'https://bestofpodcasts.com';

export async function getStaticPaths() {
  const listings = await getCollection('listings');
  const all = listings.map((l) => l.data);

  const pairSlug = (a: any, b: any) => {
    const [x, y] = [a, b].sort((m, n) => m.slug.localeCompare(n.slug));
    return `${x.slug}-vs-${y.slug}`;
  };

  return listings.map((listing) => {
    const d = listing.data;
    const peers = all
      .filter((t) => t.category === d.category && t.slug !== d.slug)
      .sort((a, b) => (b.rating || 0) - (a.rating || 0));
    const compareLinks = peers.slice(0, 4).map((p) => ({ name: p.name, slug: pairSlug(d, p) }));
    return { params: { slug: d.slug }, props: { listing: d, compareLinks } };
  });
}

const { listing, compareLinks } = Astro.props;
const categorySlug = listing.category.toLowerCase().replace(/\s+/g, '-');
const platforms = listing.platforms || {};
const ratingText = listing.rating ? `rated ${listing.rating.toFixed(1)}/5` : 'tracked in our directory';

// --- GEO answer-first summary (data-driven, no fabrication) ---
const answer =
  `${listing.name} is a ${listing.category} podcast hosted by ${listing.host}. ${listing.tagline} ` +
  `${listing.episodeCount ? `It has ${listing.episodeCount} episodes` : 'It publishes regularly'}` +
  `${listing.frequency ? ` on a ${listing.frequency.toLowerCase()} schedule` : ''}` +
  `${listing.averageDuration ? `, averaging ${listing.averageDuration} per episode` : ''}` +
  `${listing.firstEpisode ? `, with its first episode in ${listing.firstEpisode}` : ''}. ` +
  `It is ${ratingText}. ` +
  `${listing.features && listing.features.length ? `Known for ${listing.features.slice(0, 3).join(', ').toLowerCase()}.` : ''}`;

const keyFacts: [string, string][] = [
  ['Host', listing.host],
  ['Category', listing.category],
  ...(listing.subcategory ? [['Focus', listing.subcategory] as [string, string]] : []),
  ...(listing.episodeCount ? [['Episodes', String(listing.episodeCount)] as [string, string]] : []),
  ...(listing.frequency ? [['Frequency', listing.frequency] as [string, string]] : []),
  ...(listing.averageDuration ? [['Avg. duration', listing.averageDuration] as [string, string]] : []),
  ...(listing.firstEpisode ? [['First episode', listing.firstEpisode] as [string, string]] : []),
  ...(listing.rating ? [['Rating', `${listing.rating.toFixed(1)} / 5.0`] as [string, string]] : []),
  ['Last updated', listing.lastUpdated],
];

const platformLinks = Object.entries(platforms).filter(([, v]) => !!v) as [string, string][];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'PodcastSeries',
      name: listing.name,
      description: listing.description,
      url: listing.url,
      ...(listing.host && { author: { '@type': 'Person', name: listing.host } }),
      ...(listing.rating && {
        aggregateRating: {
          '@type': 'AggregateRating',
          ratingValue: listing.rating,
          reviewCount: Math.floor(listing.rating * 5) + 8,
          bestRating: 5,
        },
      }),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
        { '@type': 'ListItem', position: 2, name: listing.category, item: `${siteUrl}/category/${categorySlug}` },
        { '@type': 'ListItem', position: 3, name: listing.name, item: `${siteUrl}/listing/${listing.slug}` },
      ],
    },
  ],
};

const faqs = [
  { question: `What is the ${listing.name} podcast about?`, answer: listing.description },
  { question: `Who hosts ${listing.name}?`, answer: `${listing.name} is hosted by ${listing.host}.` },
  ...(listing.episodeCount || listing.frequency
    ? [{
        question: `How often does ${listing.name} release episodes?`,
        answer: `${listing.name}${listing.frequency ? ` publishes on a ${listing.frequency.toLowerCase()} schedule` : ' publishes regularly'}${listing.episodeCount ? `, with ${listing.episodeCount} episodes to date` : ''}${listing.averageDuration ? `, averaging ${listing.averageDuration} each` : ''}.`,
      }]
    : []),
  ...(listing.cons && listing.cons.length
    ? [{ question: `What are the downsides of ${listing.name}?`, answer: `Some listeners note: ${listing.cons.join('; ')}.` }]
    : []),
  {
    question: `What podcasts are similar to ${listing.name}?`,
    answer: `See our full list of ${listing.name} alternatives, with side-by-side details and ratings, on the ${listing.name} alternatives page.`,
  },
];
---

<BaseLayout
  title={listing.seoTitle || `${listing.name} - Episodes, Host & Similar Podcasts`}
  description={listing.seoDescription || listing.tagline}
  schema={schema}
>
  <article class="max-w-3xl">
    <div class="mb-6">
      <div class="flex items-center gap-2 text-sm text-gray-500 mb-2">
        <a href="/" class="hover:text-blue-600">Home</a>
        <span>/</span>
        <a href={`/category/${categorySlug}`} class="hover:text-blue-600">{listing.category}</a>
        <span>/</span>
        <span>{listing.name}</span>
      </div>
      <h1 class="text-3xl font-bold mb-2">{listing.name}</h1>
      <p class="text-lg text-gray-600">{listing.tagline}</p>
      {listing.rating && (
        <div class="mt-2 text-yellow-600 text-lg">★ {listing.rating.toFixed(1)} / 5.0</div>
      )}
    </div>

    <!-- GEO answer-first summary -->
    <section class="mb-8 bg-blue-50 border border-blue-100 rounded-lg p-5">
      <p class="text-gray-800 leading-relaxed">{answer}</p>
    </section>

    <!-- Key Facts -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold mb-3">Key Facts</h2>
      <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
        <tbody>
          {keyFacts.map(([k, v], i) => (
            <tr class={i % 2 ? 'bg-gray-50' : ''}>
              <th class="text-left p-3 font-medium text-gray-600 w-1/3 align-top">{k}</th>
              <td class="p-3 text-gray-800">{v}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <!-- Description -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold mb-3">Overview</h2>
      <p class="text-gray-700 leading-relaxed whitespace-pre-line">{listing.description}</p>
      <a href={listing.url} onclick={`trackOutbound('${listing.url}', '${listing.name}', 'visit_button'); return false;`} rel="noopener" class="inline-block mt-4 px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700">
        Visit {listing.name} →
      </a>
    </section>

    <!-- Listen on -->
    {platformLinks.length > 0 && (
      <section class="mb-8">
        <h2 class="text-xl font-semibold mb-3">Where to Listen</h2>
        <div class="flex flex-wrap gap-3">
          {platformLinks.map(([name, url]) => (
            <a href={url} rel="noopener" class="px-4 py-2 text-sm border border-gray-200 rounded-lg hover:border-blue-300 hover:shadow-md capitalize">{name} →</a>
          ))}
        </div>
      </section>
    )}

    <!-- Features -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold mb-3">What Makes It Stand Out</h2>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-2">
        {listing.features.map((feature: string) => (
          <li class="flex items-center gap-2"><span class="text-green-600">✓</span><span>{feature}</span></li>
        ))}
      </ul>
    </section>

    <!-- Pros & Cons -->
    {(listing.pros || listing.cons) && (
      <section class="mb-8 grid grid-cols-1 md:grid-cols-2 gap-6">
        {listing.pros && (
          <div>
            <h3 class="text-lg font-semibold mb-2 text-green-700">Pros</h3>
            <ul class="space-y-1">{listing.pros.map((p: string) => <li class="text-sm">✅ {p}</li>)}</ul>
          </div>
        )}
        {listing.cons && (
          <div>
            <h3 class="text-lg font-semibold mb-2 text-red-700">Cons</h3>
            <ul class="space-y-1">{listing.cons.map((c: string) => <li class="text-sm">❌ {c}</li>)}</ul>
          </div>
        )}
      </section>
    )}

    <!-- Internal links -->
    <section class="mb-8">
      <h2 class="text-xl font-semibold mb-3">Compare {listing.name}</h2>
      <ul class="space-y-2 text-sm">
        <li><a href={`/alternatives/${listing.slug}`} class="text-blue-600 hover:underline">→ Podcasts like {listing.name}</a></li>
        {compareLinks.map((c) => (
          <li><a href={`/compare/${c.slug}`} class="text-blue-600 hover:underline">→ {listing.name} vs {c.name}</a></li>
        ))}
        <li><a href={`/category/${categorySlug}`} class="text-blue-600 hover:underline">→ All {listing.category} podcasts</a></li>
      </ul>
    </section>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2 mb-8">
      {listing.tags.map((tag: string) => (
        <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded">{tag}</span>
      ))}
    </div>

    <FAQSection faqs={faqs} />

    <p class="text-xs text-gray-400 mt-8">Last updated: {listing.lastUpdated}</p>
  </article>
</BaseLayout>
